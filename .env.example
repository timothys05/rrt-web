# Copy this file to .env and fill in your Azure Blob Storage details.
# Do NOT commit .env to source control.

# Base URL for your Azure Blob Storage container (no trailing slash)
# e.g. https://myaccount.blob.core.windows.net/reports
REACT_APP_AZURE_URL=https://YOUR_ACCOUNT.blob.core.windows.net/YOUR_CONTAINER/

# SAS token string (everything after the '?' in your SAS URL)
# e.g. sv=2022-11-02&ss=b&srt=o&sp=w&...
REACT_APP_AZURE_SAS_TOKEN=YOUR_SAS_TOKEN
